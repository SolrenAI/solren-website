# Contact form email delivery (Google Workspace SMTP via Nodemailer)
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Google Workspace SMTP server.
SMTP_HOST=smtp.gmail.com

# 465 = implicit TLS (recommended), or 587 = STARTTLS.
SMTP_PORT=465

# The Google Workspace mailbox that sends the enquiries (the authenticated user).
SMTP_USER=contact@solren.ai

# App Password for SMTP_USER, NOT the account login password.
# Requires 2-Step Verification on the account, then create one at
# https://myaccount.google.com/apppasswords (paste the 16 characters, no spaces).
SMTP_PASS=your-16-char-app-password

# Where enquiries are delivered.
CONTACT_TO=contact@solren.ai
