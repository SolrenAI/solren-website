# Lead form delivery (n8n backend)
# Copy this file to .env.local and fill in the real value. .env.local is gitignored.

# The website lead form posts to /api/lead (server-side), which forwards the
# submission to this n8n webhook. Server-only — do NOT prefix with NEXT_PUBLIC_,
# so the webhook URL is never exposed in browser code.
SOLREN_N8N_LEAD_WEBHOOK_URL=https://your-n8n-host/webhook/your-lead-webhook-id

# S00 Universal Lead Intake webhook. /api/jinksy-lead and /api/quote-lead
# forward validated enquiries here with the client's install_key. Server-only.
SOLREN_S00_LEAD_WEBHOOK_URL=https://your-n8n-host/webhook/your-s00-webhook-id

# Supabase (multi-tenant quote pages, /q/[slug]). The publishable (anon) key
# calls the public get_public_quote_config RPC server-side
# (lib/quote/config.ts) — the only Supabase surface this site touches. No
# service-role key is used anywhere. Server-only — no NEXT_PUBLIC_ prefix.
SOLREN_SUPABASE_URL=https://your-project-ref.supabase.co
SOLREN_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
